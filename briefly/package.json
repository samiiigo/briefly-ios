{
  "name": "briefly",
  "version": "5.2.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --dev-client",
    "start:clean": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --dev-client -c",
    "dev:android": "expo run:android",
    "dev:ios": "expo run:ios",
    "ios": "expo run:ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform all",
    "build:prod:ios": "eas build --profile production --platform ios",
    "build:prod:android": "eas build --profile production --platform android",
    "submit:prod": "eas submit --profile production --platform all --latest",
    "submit:prod:ios": "eas submit --profile production --platform ios --latest",
    "submit:prod:android": "eas submit --profile production --platform android --latest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "tsx --test src/**/*.test.ts",
    "audit:ci": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm test && npm run audit:ci",
    "preinstall": "node ./scripts/prepare-llama-windows-install.js",
    "install:win": "node ./scripts/prepare-llama-windows-install.js && npm install",
    "postinstall": "node ./scripts/postinstall-llama-if-windows.js",
    "postinstall:llama": "node ./scripts/postinstall-llama.js",
    "android": "expo run:android"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-live-activity": "^0.4.2",
    "expo-navigation-bar": "~5.0.10",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "llama.rn": "^0.12.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "react-dom": "19.1.0",
    "@xmldom/xmldom": "0.8.13",
    "postcss": "8.5.14",
    "glob": "^13.0.6",
    "rimraf": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
