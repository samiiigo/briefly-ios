# Copy to .env for local builds (never commit .env).
# EAS Build: use non-public secrets — `eas secret:create --scope project`
#
# OWASP: do NOT use EXPO_PUBLIC_* for production shared keys (they embed in the JS bundle).
# Prefer ASSEMBLYAI_API_KEY and OPENROUTER_SHARED_API_KEY (injected at build via app.config.js → expo.extra).

ASSEMBLYAI_API_KEY=
OPENROUTER_SHARED_API_KEY=

# Legacy local dev only (avoid in production builds):
# EXPO_PUBLIC_ASSEMBLYAI_API_KEY=
# EXPO_PUBLIC_OPENROUTER_API_KEY=
