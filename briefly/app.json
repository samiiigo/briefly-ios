{
  "expo": {
    "name": "Briefly",
    "slug": "briefly",
    "scheme": "briefly",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#000000",
      "bundleIdentifier": "com.briefly.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Briefly needs microphone access to record audio for transcription.",
        "NSSpeechRecognitionUsageDescription": "Briefly uses on-device speech recognition to transcribe your recordings privately.",
        "NSMicrophoneUsageDescriptionAlways": "Briefly needs microphone access to record audio.",
        "ASSEMBLYAI_API_KEY": ""
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.briefly.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "assemblyAiApiKey": "",
      "openRouterSharedApiKey": "",
      "router": {},
      "eas": {
        "projectId": "a76ad650-f9a8-479c-ad81-a666f586a7dc"
      }
    },
    "owner": "samiiigo"
  }
}
