{
  "expo": {
    "name": "Briefly",
    "slug": "briefly",
    "scheme": "briefly",
    "version": "3.6.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#000000",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#000000",
      "bundleIdentifier": "com.briefly.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Briefly needs microphone access to record audio for transcription.",
        "NSSpeechRecognitionUsageDescription": "Briefly uses on-device speech recognition to transcribe your recordings privately.",
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {}
    },
    "android": {
      "package": "com.briefly.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Briefly needs microphone access to record audio for transcription.",
          "enableBackgroundRecording": true
        }
      ],
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-asset",
      "expo-live-activity",
      [
        "llama.rn",
        {
          "enableEntitlements": true,
          "entitlementsProfile": "production",
          "forceCxx20": true,
          "enableOpenCLAndHexagon": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a76ad650-f9a8-479c-ad81-a666f586a7dc"
      }
    },
    "owner": "samiiigo",
    "updates": {
      "url": "https://u.expo.dev/a76ad650-f9a8-479c-ad81-a666f586a7dc"
    }
  }
}
