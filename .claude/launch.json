{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "expo",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Expo Dev Server (clean cache)",
      "runtimeExecutable": "expo",
      "runtimeArgs": ["start", "-c"],
      "port": 8081
    },
    {
      "name": "iOS Native Build",
      "runtimeExecutable": "expo",
      "runtimeArgs": ["run:ios"],
      "port": 8081
    },
    {
      "name": "Android Native Build",
      "runtimeExecutable": "expo",
      "runtimeArgs": ["run:android"],
      "port": 8081
    }
  ]
}
